---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import AlphaBanner from '../components/AlphaBanner.astro';
import Footer from '../components/Footer.astro';
import benchmark from '../data/benchmark';

const benchmarkJSON = JSON.stringify(benchmark);
const tokenizerOptions = Object.entries(benchmark.models).sort(([, a], [, b]) =>
  a.name.localeCompare(b.name)
);
---

<Base title="mothertoken — benchmark explorer">
  <div class="max-w-[1120px] mx-auto pt-12 px-6 pb-24">
    <Nav activeTab="benchmark" />
    <AlphaBanner />

    <div class="flex items-center gap-4 mb-8 animate-fade-in-up stagger-1">
      <span class="font-mono text-[13px] tracking-[.15em] text-text-tertiary uppercase whitespace-nowrap">benchmark explorer</span>
      <span class="flex-1 h-[1px] bg-border-strong opacity-40"></span>
    </div>

    <div class="flex flex-wrap items-center gap-5 mb-10 animate-fade-in-up stagger-1">
      <div class="flex items-center gap-2.5">
        <span class="font-mono text-[15px] text-text-secondary">tokenizer</span>
        <select id="model-sel" class="bg-bg border border-border-strong rounded-md py-2 px-3 font-mono text-[15px] text-text outline-none focus:border-text transition-colors duration-300 cursor-pointer min-w-[170px] shadow-sm">
          {tokenizerOptions.map(([id, m]) => (
            <option value={id} class="bg-bg text-text">
              {m.usedByExamples.length ? `${m.name} (${m.usedByExamples.join(', ')})` : m.name}
            </option>
          ))}
        </select>
      </div>
      <div class="flex items-center gap-2.5">
        <span class="font-mono text-[15px] text-text-secondary">sort</span>
        <select id="sort-sel" class="bg-bg border border-border-strong rounded-md py-2 px-3 font-mono text-[15px] text-text outline-none focus:border-text transition-colors duration-300 cursor-pointer min-w-[190px] shadow-sm">
          <option value="asc" class="bg-bg text-text">most efficient first</option>
          <option value="desc" class="bg-bg text-text">least efficient first</option>
          <option value="alpha" class="bg-bg text-text">alphabetical</option>
        </select>
      </div>
      <p class="basis-full text-[18px] text-text-tertiary leading-[1.6] max-w-[760px]">
        MotherToken benchmarks tokenizers. Model names are shown as examples because several models can share the same tokenizer.
      </p>
    </div>

    <div class="data-table-scroll mb-16 animate-fade-in-up stagger-2" style="--table-row-height: 57px;">
      <table class="w-full border-collapse text-[18px] table-fixed" id="full-table">
        <thead>
          <tr>
            <th class="font-mono text-[13px] tracking-[.1em] text-text-tertiary font-normal text-left py-3.5 px-4 border-b border-border w-[25%]">language</th>
            <th class="font-mono text-[13px] tracking-[.1em] text-text-tertiary font-normal text-left py-3.5 px-4 border-b border-border w-[12%]">script</th>
            <th class="font-mono text-[13px] tracking-[.1em] text-text-tertiary font-normal text-right py-3.5 px-4 border-b border-border w-[22%]">chars/token</th>
            <th class="font-mono text-[13px] tracking-[.1em] text-text-tertiary font-normal text-right py-3.5 px-4 border-b border-border w-[17%]">fertility</th>
            <th class="font-mono text-[13px] tracking-[.1em] text-text-tertiary font-normal text-center py-3.5 px-4 border-b border-border w-[24%]">efficiency (rtc)</th>
          </tr>
        </thead>
        <tbody id="full-body"></tbody>
      </table>
    </div>

    <Footer />
  </div>
</Base>

<script define:vars={{ benchmarkJSON }}>
  const benchmark = JSON.parse(benchmarkJSON);
  const MODELS = Object.keys(benchmark.models);
  const LANGS = benchmark.languages;

  function getRTC(modelId, langId) {
    const m = benchmark.models[modelId];
    if (!m || !m.metrics[langId] || !m.metrics[benchmark.baseline]) return 1;
    return m.metrics[benchmark.baseline].cpt / m.metrics[langId].cpt;
  }

  function detectLang() {
    const map = {
      th: 'tha', ar: 'ara', ja: 'jpn', zh: 'zho',
      hi: 'hin', pt: 'por', fr: 'fra', de: 'deu',
      tr: 'tur', uk: 'ukr', vi: 'vie', sw: 'swa',
      es: 'spa', ko: 'kor',
    };
    const locales = navigator.languages?.length ? navigator.languages : [navigator.language || 'en-US'];
    const matchedLocale = locales.find(locale => map[locale.split('-')[0]]);
    const locale = matchedLocale || locales[0] || 'en-US';
    const code = locale.split('-')[0];
    return map[code] || benchmark.baseline;
  }

  function highestRTCModel(langId) {
    return MODELS.reduce((highest, mid) => (
      getRTC(mid, langId) > getRTC(highest, langId) ? mid : highest
    ), MODELS[0]);
  }

  function badge(r) {
    const cls = r <= 1.3 
      ? 'bg-good-bg text-good-text border-good/20' 
      : r <= 2.0 
      ? 'bg-mid-bg text-mid-text border-mid/20' 
      : 'bg-bad-bg text-bad-text border-bad/20';
    return `<span class="font-mono text-[13px] px-3 py-1.5 rounded-full font-medium whitespace-nowrap border ${cls}">${r.toFixed(1)}×</span>`;
  }

  function renderTable() {
    const mid = document.getElementById('model-sel').value;
    const sort = document.getElementById('sort-sel').value;

    let rows = Object.entries(LANGS)
      .filter(([lid]) => lid !== benchmark.baseline)
      .map(([lid, l]) => {
        const d = benchmark.models[mid].metrics[lid] || { cpt: 0, fert: 0 };
        const r = getRTC(mid, lid);
        return { lid, ...l, cpt: d.cpt, fert: d.fert, r };
      });

    if (sort === 'asc')  rows.sort((a, b) => a.r - b.r);
    else if (sort === 'desc') rows.sort((a, b) => b.r - a.r);
    else rows.sort((a, b) => a.name.localeCompare(b.name));

    document.getElementById('full-body').innerHTML = rows.map(row => `
      <tr class="group hover:bg-bg-secondary transition-colors duration-300 ease-quint cursor-default">
        <td class="font-medium py-4 px-4 border-b border-border align-middle text-text-secondary group-hover:text-text transition-colors duration-300">${row.name}</td>
        <td class="font-mono text-[14px] text-text-tertiary py-4 px-4 border-b border-border align-middle">${row.script}</td>
        <td class="font-mono text-[16px] text-text-secondary text-right py-4 px-4 border-b border-border align-middle">${row.cpt.toFixed(1)}</td>
        <td class="font-mono text-[16px] text-text-secondary text-right py-4 px-4 border-b border-border align-middle">${row.fert.toFixed(2)}</td>
        <td class="text-center py-4 px-4 border-b border-border align-middle">${badge(row.r)}</td>
      </tr>`).join('');
  }

  document.getElementById('model-sel').addEventListener('change', renderTable);
  document.getElementById('sort-sel').addEventListener('change', renderTable);

  document.getElementById('model-sel').value = highestRTCModel(detectLang());
  renderTable();
</script>
