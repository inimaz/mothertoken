---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import AlphaBanner from '../components/AlphaBanner.astro';
import Footer from '../components/Footer.astro';
import benchmark from '../data/benchmark';

// Serialize benchmark data for the client-side island
const benchmarkJSON = JSON.stringify(benchmark);
const languageOptions = Object.entries(benchmark.languages).sort(([, a], [, b]) =>
  a.name.localeCompare(b.name)
);
---

<Base>
  <div class="max-w-[1120px] mx-auto pt-12 px-6 pb-24">
    <Nav activeTab="home" />
    
    <section class="mb-14 animate-fade-in-up stagger-1">
      <div class="flex flex-wrap items-center gap-3 mb-6">
        <span class="pulse"></span>
        <span class="font-mono text-[14px] text-text-tertiary" id="locale-label">detecting locale...</span>
        <div class="language-picker">
          <label class="sr-only" for="language-sel">language</label>
          <select id="language-sel" aria-describedby="language-hint" class="bg-bg border border-border-strong rounded-md py-2 px-3 font-mono text-[15px] text-text outline-none focus:border-text transition-colors duration-300 cursor-pointer min-w-[170px] shadow-sm">
            {languageOptions.map(([id, language]) => (
              <option value={id} class="bg-bg text-text">{language.name}</option>
            ))}
          </select>
          <span id="language-hint" class="language-hint" hidden>try other languages</span>
        </div>
      </div>
      <h1 class="text-[3.5rem] font-medium leading-[1.06] text-text mb-6 tracking-tight">Every model has a <span class="text-text-tertiary">native tongue.</span><br>The question is whether yours matches.</h1>
      <p class="text-[21px] text-text-secondary leading-[1.6] max-w-[680px] mb-12">
        Tokenizer efficiency is a proxy for how well a model understands your language.
        The same content in Thai needs 2.8× more tokens than in English —
        less effective context window, worse reasoning, higher cost multiplier.
      </p>
    </section>
    
    <AlphaBanner />
    <section class="animate-fade-in-up stagger-2">
      <div class="flex flex-col gap-4 mb-6 sm:flex-row sm:items-center">
        <div class="flex items-center gap-4 min-w-0 flex-1">
          <span class="font-mono text-[13px] tracking-[.15em] text-text-tertiary uppercase whitespace-nowrap" id="analysis-label">compare tokenizers</span>
          <span class="hidden sm:block flex-1 h-[1px] bg-border-strong opacity-40"></span>
        </div>
        <div class="inline-grid grid-cols-2 gap-px bg-border p-px rounded-lg w-full sm:w-auto" role="tablist" aria-label="analysis view">
          <button
            type="button"
            id="compare-view-tab"
            data-view-tab="compare"
            class="view-tab rounded-[7px] py-2.5 px-4 font-mono text-[13px] transition-colors duration-300 bg-bg text-text shadow-sm"
            role="tab"
            aria-selected="true"
            aria-controls="compare-view"
          >
            compare
          </button>
          <button
            type="button"
            id="cost-view-tab"
            data-view-tab="cost"
            class="view-tab rounded-[7px] py-2.5 px-4 font-mono text-[13px] transition-colors duration-300 text-text-tertiary hover:text-text"
            role="tab"
            aria-selected="false"
            aria-controls="cost-view"
          >
            cost
          </button>
        </div>
      </div>

      <div id="compare-view" data-view-panel="compare" role="tabpanel" aria-labelledby="compare-view-tab">
        <div class="data-table-scroll mb-10" style="--table-row-height: 76px;">
          <table class="w-full border-collapse table-fixed" id="hero-table">
            <thead>
              <tr>
                <th class="font-mono text-[13px] tracking-[.1em] text-text-tertiary font-normal text-left py-3.5 px-4 border-b border-border w-10">#</th>
                <th class="font-mono text-[13px] tracking-[.1em] text-text-tertiary font-normal text-left py-3.5 px-4 border-b border-border w-[35%]">tokenizer</th>
                <th class="font-mono text-[13px] tracking-[.1em] text-text-tertiary font-normal text-right py-3.5 px-4 border-b border-border w-[18%]">chars/token</th>
                <th class="font-mono text-[13px] tracking-[.1em] text-text-tertiary font-normal text-right py-3.5 px-4 border-b border-border w-[18%]">fertility</th>
                <th class="font-mono text-[13px] tracking-[.1em] text-text-tertiary font-normal text-right py-3.5 px-4 border-b border-border w-[14%]">vs english</th>
                <th class="font-mono text-[13px] tracking-[.1em] text-text-tertiary font-normal text-left py-3.5 px-4 border-b border-border w-[15%]">efficiency</th>
              </tr>
            </thead>
            <tbody id="hero-body">
              <tr><td colspan="6" class="font-mono text-[16px] text-text-tertiary py-8 px-4 border-b border-border text-center">detecting your language...</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <div id="cost-view" data-view-panel="cost" role="tabpanel" aria-labelledby="cost-view-tab" hidden>
        <div class="bg-bg-secondary p-6 rounded-xl border border-border shadow-[0_2px_8px_-2px_rgba(0,0,0,0.05),0_1px_2px_rgba(0,0,0,0.02)] mb-10">
          <div class="flex items-center gap-3 mb-5 flex-wrap">
            <span class="font-mono text-[15px] text-text-secondary">your token rate / 1m</span>
            <div class="relative flex items-center">
              <span class="absolute left-3 font-mono text-[15px] text-text-tertiary">$</span>
              <input type="number" id="calc-rate" value="10" min="0" step="0.5" class="bg-bg border border-border-strong rounded-md py-2 pl-7 pr-3 font-mono text-[15px] text-text w-[110px] outline-none focus:border-text transition-colors duration-300" />
            </div>
          </div>
          <div class="border-t border-border pt-4 flex flex-col gap-2" id="calc-results"></div>
          <p class="font-mono text-[13px] text-text-tertiary mt-6 leading-[1.6]">
            * mothertoken owns no pricing data. the rtc multiplier is yours to apply.<br />
            whatever you pay per token × multiplier = what your language actually costs.
          </p>
        </div>
      </div>
    </section>

    <div class="grid grid-cols-3 gap-px bg-border rounded-xl overflow-hidden mb-8 animate-fade-in-up stagger-3" id="insight-strip"></div>

    <Footer />
  </div>
</Base>

<script define:vars={{ benchmarkJSON }}>
  const benchmark = JSON.parse(benchmarkJSON);
  const MODELS = Object.keys(benchmark.models);
  const languageSelect = document.getElementById('language-sel');
  const languageHint = document.getElementById('language-hint');
  const analysisLabel = document.getElementById('analysis-label');
  const viewTabs = document.querySelectorAll('[data-view-tab]');
  const viewPanels = document.querySelectorAll('[data-view-panel]');
  let activeLangId = benchmark.baseline;
  let activeView = 'compare';

  function getRTC(modelId, langId) {
    const m = benchmark.models[modelId];
    if (!m || !m.metrics[langId] || !m.metrics[benchmark.baseline]) return 1;
    return m.metrics[benchmark.baseline].cpt / m.metrics[langId].cpt;
  }

  function fillBgColor(r) {
    return r <= 1.3 ? 'var(--theme-good)' : r <= 2.0 ? 'var(--theme-mid)' : 'var(--theme-bad)';
  }

  function textColorClass(r) {
    return r <= 1.3 ? 'text-good-text' : r <= 2.0 ? 'text-mid-text' : 'text-bad-text';
  }

  function strokeColor(r) {
    return r <= 1.3 ? 'text-good' : r <= 2.0 ? 'text-mid' : 'text-bad';
  }

  function badge(r) {
    const cls = r <= 1.3 
      ? 'bg-good-bg text-good-text border-good/20' 
      : r <= 2.0 
      ? 'bg-mid-bg text-mid-text border-mid/20' 
      : 'bg-bad-bg text-bad-text border-bad/20';
    return `<span class="font-mono text-[13px] px-3 py-1.5 rounded-full font-medium whitespace-nowrap border ${cls}">${r.toFixed(1)}×</span>`;
  }

  function escapeHTML(value) {
    return String(value).replace(/[&<>"']/g, char => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#39;',
    })[char]);
  }

  function usedByText(model) {
    return model.usedByExamples?.length ? model.usedByExamples.join(', ') : 'model family varies';
  }

  function setAnalysisLabel() {
    const lang = benchmark.languages[activeLangId];
    analysisLabel.textContent = activeView === 'cost'
      ? `${lang.name} cost multiplier`
      : `${lang.name} across tokenizers`;
  }

  function updateLanguageHint() {
    languageHint.hidden = activeLangId !== benchmark.baseline;
  }

  function setView(view) {
    activeView = view;
    viewTabs.forEach(tab => {
      const isActive = tab.dataset.viewTab === view;
      tab.setAttribute('aria-selected', String(isActive));
      tab.classList.toggle('bg-bg', isActive);
      tab.classList.toggle('text-text', isActive);
      tab.classList.toggle('shadow-sm', isActive);
      tab.classList.toggle('text-text-tertiary', !isActive);
    });
    viewPanels.forEach(panel => {
      panel.hidden = panel.dataset.viewPanel !== view;
    });
    setAnalysisLabel();
  }

  function tokenizerLabel(model) {
    return `
      <div class="font-medium text-text-secondary group-hover:text-text transition-colors duration-300">${escapeHTML(model.name)}</div>
      <div class="font-mono text-[14px] text-text-tertiary mt-1 leading-[1.35]">used by ${escapeHTML(usedByText(model))}</div>
    `;
  }

  function detectLang() {
    const map = {
      th: 'tha', ar: 'ara', ja: 'jpn', zh: 'zho',
      hi: 'hin', pt: 'por', fr: 'fra', de: 'deu',
      tr: 'tur', uk: 'ukr', vi: 'vie', sw: 'swa',
    };
    const locales = navigator.languages?.length ? navigator.languages : [navigator.language || 'en-US'];
    const matchedLocale = locales.find(locale => map[locale.split('-')[0]]);
    const locale = matchedLocale || locales[0] || 'en-US';
    const code = locale.split('-')[0];
    return { lid: map[code] || benchmark.baseline, locale };
  }

  function renderHero(lid = activeLangId) {
    activeLangId = lid;
    const lang = benchmark.languages[activeLangId];

    languageSelect.value = activeLangId;
    setAnalysisLabel();
    updateLanguageHint();

    const rows = MODELS.map(mid => {
      const model = benchmark.models[mid];
      const d = benchmark.models[mid].metrics[activeLangId] || { cpt: 0, fert: 0 };
      const r = getRTC(mid, activeLangId);
      return { mid, model, name: model.name, cpt: d.cpt, fert: d.fert, r };
    }).sort((a, b) => a.r - b.r);

    const maxR = Math.max(...rows.map(x => x.r));

    document.getElementById('hero-body').innerHTML = rows.map((row, i) => `
      <tr class="group hover:bg-bg-secondary transition-colors duration-300 ease-quint cursor-default">
        <td class="font-mono text-[13px] text-text-tertiary w-8 py-4 px-4 border-b border-border align-middle">${i + 1}</td>
        <td class="text-[19px] py-4 px-4 border-b border-border align-middle">${tokenizerLabel(row.model)}</td>
        <td class="font-mono text-[16px] text-text-secondary text-right py-4 px-4 border-b border-border align-middle">${row.cpt.toFixed(1)}</td>
        <td class="font-mono text-[16px] text-text-secondary text-right py-4 px-4 border-b border-border align-middle">${row.fert.toFixed(2)}</td>
        <td class="py-4 px-4 border-b border-border align-middle">
          <div class="flex items-center gap-3 justify-end">
            <div class="w-full max-w-[70px] h-[3px] bg-border-strong rounded-full overflow-hidden">
              <div class="h-full rounded-full transition-all duration-700 ease-quint" style="width:${Math.round((row.r / maxR) * 100)}%;background:${fillBgColor(row.r)}"></div>
            </div>
          </div>
        </td>
        <td class="py-4 px-4 border-b border-border align-middle pr-4">${badge(row.r)}</td>
      </tr>`).join('');

    const best = rows[0];
    const worst = rows[rows.length - 1];
    const spread = Math.round(((worst.r / best.r) - 1) * 100);

    document.getElementById('insight-strip').innerHTML = `
      <div class="bg-bg py-5 px-6 flex flex-col justify-center">
        <div class="text-[13px] text-text-tertiary tracking-[.08em] uppercase mb-2 font-mono">best tokenizer</div>
        <div class="font-mono text-[1.875rem] font-medium mb-1 ${strokeColor(best.r)}">${best.name}</div>
        <div class="text-[16px] text-text-secondary">used by ${escapeHTML(usedByText(best.model))}</div>
      </div>
      <div class="bg-bg py-5 px-6 flex flex-col justify-center">
        <div class="text-[13px] text-text-tertiary tracking-[.08em] uppercase mb-2 font-mono">least efficient</div>
        <div class="font-mono text-[1.875rem] font-medium mb-1 ${strokeColor(worst.r)}">${worst.name}</div>
        <div class="text-[16px] text-text-secondary">used by ${escapeHTML(usedByText(worst.model))}</div>
      </div>
      <div class="bg-bg py-5 px-6 flex flex-col justify-center">
        <div class="text-[13px] text-text-tertiary tracking-[.08em] uppercase mb-2 font-mono">efficiency spread</div>
        <div class="font-mono text-[1.875rem] font-medium text-text mb-1">${spread}%</div>
        <div class="text-[16px] text-text-secondary">gap between best & worst</div>
      </div>`;

    renderCalc(activeLangId);
  }

  function renderCalc(lid = activeLangId) {
    const rate = parseFloat(document.getElementById('calc-rate').value) || 10;
    const rows = MODELS.map(mid => {
      const model = benchmark.models[mid];
      const r = getRTC(mid, lid);
      return { model, name: model.name, r, cost: rate * r };
    }).sort((a, b) => a.r - b.r);

    document.getElementById('calc-results').innerHTML = rows.map(row => `
      <div class="flex justify-between items-start gap-4 py-1.5">
        <span class="cursor-default select-none">
          <span class="block text-[18px] text-text-secondary font-medium transition-colors duration-300 hover:text-text">${escapeHTML(row.name)}</span>
          <span class="block font-mono text-[14px] text-text-tertiary mt-0.5">used by ${escapeHTML(usedByText(row.model))}</span>
        </span>
        <span class="text-[16px] font-medium font-mono ${textColorClass(row.r)}">
          ${row.r.toFixed(1)}×
          <span class="text-text-tertiary text-[14px] ml-2">($${row.cost.toFixed(2)}/1M tags)</span>
        </span>
      </div>`).join('');
  }

  document.getElementById('calc-rate').addEventListener('input', () => renderCalc());
  viewTabs.forEach(tab => {
    tab.addEventListener('click', () => setView(tab.dataset.viewTab));
  });
  languageSelect.addEventListener('change', event => {
    document.getElementById('locale-label').textContent = 'manual language selection';
    renderHero(event.target.value);
  });

  const detected = detectLang();
  activeLangId = benchmark.languages[detected.lid] ? detected.lid : benchmark.baseline;
  document.getElementById('locale-label').textContent =
    `${detected.locale} — ${benchmark.languages[activeLangId].name} detected`;
  renderHero(activeLangId);
</script>

<style>
  .language-picker {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    min-width: 0;
  }

  .language-hint {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.3;
    color: var(--theme-text-tertiary);
    white-space: nowrap;
  }

  .language-hint::before {
    content: "";
    display: block;
    width: 28px;
    height: 1px;
    background: color-mix(in srgb, var(--theme-text-tertiary) 62%, transparent);
  }

  .language-hint::after {
    content: "";
    position: absolute;
    left: 0;
    width: 7px;
    height: 7px;
    border-left: 1px solid color-mix(in srgb, var(--theme-text-tertiary) 70%, transparent);
    border-bottom: 1px solid color-mix(in srgb, var(--theme-text-tertiary) 70%, transparent);
    transform: rotate(45deg);
  }

  @media (max-width: 640px) {
    .language-picker {
      flex-wrap: wrap;
      row-gap: 0.5rem;
    }

    .language-hint {
      flex-basis: 100%;
      margin-left: 0.25rem;
      white-space: normal;
    }

    .language-hint::before,
    .language-hint::after {
      display: none;
    }
  }
</style>
