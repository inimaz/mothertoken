---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import AlphaBanner from '../components/AlphaBanner.astro';
import Footer from '../components/Footer.astro';
import benchmark from '../data/benchmark';

// Serialize benchmark data for the client-side island
const benchmarkJSON = JSON.stringify(benchmark);
---

<Base>
  <div class="max-w-[760px] mx-auto pt-12 px-6 pb-24">
    <Nav activeTab="home" />
    <AlphaBanner />
    
    <section class="mb-14 animate-fade-in-up stagger-1">
      <div class="flex items-center gap-3 mb-6">
        <span class="pulse"></span>
        <span class="font-mono text-[11px] text-text-tertiary" id="locale-label">detecting locale...</span>
      </div>
      <h1 class="text-[2.25rem] font-medium leading-[1.1] text-text mb-4 tracking-tight">Every model has a <span class="text-text-tertiary">native tongue.</span><br>The question is whether yours matches.</h1>
      <p class="text-[14.5px] text-text-secondary leading-[1.65] max-w-[540px] mb-10">
        Tokenizer efficiency is a proxy for how well a model understands your language.
        The same content in Thai needs 2.8× more tokens than in English —
        less effective context window, worse reasoning, higher cost multiplier.
      </p>
    </section>
    
    <div class="flex items-center gap-4 mb-6 animate-fade-in-up stagger-2">
      <span class="font-mono text-[10px] tracking-[.15em] text-text-tertiary uppercase whitespace-nowrap" id="hero-lang-label">your language on all models</span>
      <span class="flex-1 h-[1px] bg-border-strong opacity-40"></span>
    </div>

    <table class="w-full border-collapse mb-10 animate-fade-in-up stagger-2 table-fixed" id="hero-table">
      <thead>
        <tr>
          <th class="font-mono text-[10px] tracking-[.1em] text-text-tertiary font-normal text-left py-3 px-4 border-b border-border w-10">#</th>
          <th class="font-mono text-[10px] tracking-[.1em] text-text-tertiary font-normal text-left py-3 px-4 border-b border-border w-[35%]">model</th>
          <th class="font-mono text-[10px] tracking-[.1em] text-text-tertiary font-normal text-right py-3 px-4 border-b border-border w-[18%]">chars/token</th>
          <th class="font-mono text-[10px] tracking-[.1em] text-text-tertiary font-normal text-right py-3 px-4 border-b border-border w-[18%]">fertility</th>
          <th class="font-mono text-[10px] tracking-[.1em] text-text-tertiary font-normal text-right py-3 px-4 border-b border-border w-[14%]">vs english</th>
          <th class="font-mono text-[10px] tracking-[.1em] text-text-tertiary font-normal text-left py-3 px-4 border-b border-border w-[15%]">efficiency</th>
        </tr>
      </thead>
      <tbody id="hero-body">
        <tr><td colspan="6" class="font-mono text-[12px] text-text-tertiary py-8 px-4 border-b border-border text-center">detecting your language...</td></tr>
      </tbody>
    </table>

    <div class="grid grid-cols-3 gap-px bg-border rounded-xl overflow-hidden mb-8 animate-fade-in-up stagger-3" id="insight-strip"></div>

    <div class="flex items-center gap-4 mb-6 mt-14 animate-fade-in-up stagger-3">
      <span class="font-mono text-[10px] tracking-[.15em] text-text-tertiary uppercase whitespace-nowrap">cost multiplier</span>
      <span class="flex-1 h-[1px] bg-border-strong opacity-40"></span>
    </div>

    <div class="bg-bg-secondary p-6 rounded-xl border border-border animate-fade-in-up stagger-3 shadow-[0_2px_8px_-2px_rgba(0,0,0,0.05),0_1px_2px_rgba(0,0,0,0.02)]">
      <div class="flex items-center gap-3 mb-5 flex-wrap">
        <span class="font-mono text-[11px] text-text-secondary">your token rate / 1m</span>
        <div class="relative flex items-center">
          <span class="absolute left-3 font-mono text-[12px] text-text-tertiary">$</span>
          <input type="number" id="calc-rate" value="10" min="0" step="0.5" class="bg-bg border border-border-strong rounded-md py-1.5 pl-7 pr-3 font-mono text-[12px] text-text w-[100px] outline-none focus:border-text transition-colors duration-300" />
        </div>
      </div>
      <div class="border-t border-border pt-4 flex flex-col gap-2" id="calc-results"></div>
      <p class="font-mono text-[10px] text-text-tertiary mt-6 leading-[1.6]">
        * mothertoken owns no pricing data. the rtc multiplier is yours to apply.<br />
        whatever you pay per token × multiplier = what your language actually costs.
      </p>
    </div>

    <Footer />
  </div>
</Base>

<script define:vars={{ benchmarkJSON }}>
  const benchmark = JSON.parse(benchmarkJSON);
  const MODELS = Object.keys(benchmark.models);

  function getRTC(modelId, langId) {
    const m = benchmark.models[modelId];
    if (!m || !m.metrics[langId] || !m.metrics[benchmark.baseline]) return 1;
    return m.metrics[benchmark.baseline].cpt / m.metrics[langId].cpt;
  }

  function fillBgColor(r) {
    return r <= 1.3 ? 'var(--theme-good)' : r <= 2.0 ? 'var(--theme-mid)' : 'var(--theme-bad)';
  }

  function textColorClass(r) {
    return r <= 1.3 ? 'text-good-text' : r <= 2.0 ? 'text-mid-text' : 'text-bad-text';
  }

  function strokeColor(r) {
    return r <= 1.3 ? 'text-good' : r <= 2.0 ? 'text-mid' : 'text-bad';
  }

  function badge(r) {
    const cls = r <= 1.3 
      ? 'bg-good-bg text-good-text border-good/20' 
      : r <= 2.0 
      ? 'bg-mid-bg text-mid-text border-mid/20' 
      : 'bg-bad-bg text-bad-text border-bad/20';
    return `<span class="font-mono text-[10px] px-2.5 py-1 rounded-full font-medium whitespace-nowrap border ${cls}">${r.toFixed(1)}×</span>`;
  }

  function detectLang() {
    const map = {
      th: 'tha', ar: 'ara', ja: 'jpn', zh: 'zho',
      hi: 'hin', pt: 'por', fr: 'fra', de: 'deu',
      tr: 'tur', uk: 'ukr', vi: 'vie', sw: 'swa',
    };
    const locale = navigator.language || 'en-US';
    const code = locale.split('-')[0];
    return { lid: map[code] || 'tha', locale };
  }

  function renderHero() {
    const { lid, locale } = detectLang();
    const lang = benchmark.languages[lid];

    document.getElementById('locale-label').textContent =
      `${locale} — ${lang.name} detected`;
    document.getElementById('hero-lang-label').textContent =
      `${lang.name} on all models`;

    const rows = MODELS.map(mid => {
      const d = benchmark.models[mid].metrics[lid] || { cpt: 0, fert: 0 };
      const r = getRTC(mid, lid);
      return { mid, name: benchmark.models[mid].name, cpt: d.cpt, fert: d.fert, r };
    }).sort((a, b) => a.r - b.r);

    const maxR = Math.max(...rows.map(x => x.r));

    document.getElementById('hero-body').innerHTML = rows.map((row, i) => `
      <tr class="group hover:bg-bg-secondary transition-colors duration-300 ease-quint cursor-default">
        <td class="font-mono text-[10px] text-text-tertiary w-8 py-3.5 px-4 border-b border-border align-middle">${i + 1}</td>
        <td class="text-[14px] font-medium py-3.5 px-4 border-b border-border align-middle text-text-secondary group-hover:text-text transition-colors duration-300">${row.name}</td>
        <td class="font-mono text-[12px] text-text-secondary text-right py-3.5 px-4 border-b border-border align-middle">${row.cpt.toFixed(1)}</td>
        <td class="font-mono text-[12px] text-text-secondary text-right py-3.5 px-4 border-b border-border align-middle">${row.fert.toFixed(2)}</td>
        <td class="py-3.5 px-4 border-b border-border align-middle">
          <div class="flex items-center gap-3 justify-end">
            <div class="w-full max-w-[70px] h-[3px] bg-border-strong rounded-full overflow-hidden">
              <div class="h-full rounded-full transition-all duration-700 ease-quint" style="width:${Math.round((row.r / maxR) * 100)}%;background:${fillBgColor(row.r)}"></div>
            </div>
          </div>
        </td>
        <td class="py-3.5 px-4 border-b border-border align-middle pr-4">${badge(row.r)}</td>
      </tr>`).join('');

    const best = rows[0];
    const worst = rows[rows.length - 1];
    const spread = Math.round(((worst.r / best.r) - 1) * 100);

    document.getElementById('insight-strip').innerHTML = `
      <div class="bg-bg py-5 px-6 flex flex-col justify-center">
        <div class="text-[10px] text-text-tertiary tracking-[.08em] uppercase mb-1.5 font-mono">optimal model</div>
        <div class="font-mono text-[1.25rem] font-medium mb-1 ${strokeColor(best.r)}">${best.name}</div>
        <div class="text-[11px] text-text-secondary">${best.r.toFixed(1)}× relative cost</div>
      </div>
      <div class="bg-bg py-5 px-6 flex flex-col justify-center">
        <div class="text-[10px] text-text-tertiary tracking-[.08em] uppercase mb-1.5 font-mono">worst model</div>
        <div class="font-mono text-[1.25rem] font-medium mb-1 ${strokeColor(worst.r)}">${worst.name}</div>
        <div class="text-[11px] text-text-secondary">${worst.r.toFixed(1)}× relative cost</div>
      </div>
      <div class="bg-bg py-5 px-6 flex flex-col justify-center">
        <div class="text-[10px] text-text-tertiary tracking-[.08em] uppercase mb-1.5 font-mono">efficiency spread</div>
        <div class="font-mono text-[1.25rem] font-medium text-text mb-1">${spread}%</div>
        <div class="text-[11px] text-text-secondary">gap between best & worst</div>
      </div>`;

    renderCalc(lid);
  }

  function renderCalc(lid) {
    if (!lid) lid = detectLang().lid;
    const rate = parseFloat(document.getElementById('calc-rate').value) || 10;
    const rows = MODELS.map(mid => {
      const r = getRTC(mid, lid);
      return { name: benchmark.models[mid].name, r, cost: rate * r };
    }).sort((a, b) => a.r - b.r);

    document.getElementById('calc-results').innerHTML = rows.map(row => `
      <div class="flex justify-between items-center py-1">
        <span class="text-[13.5px] text-text-secondary font-medium transition-colors duration-300 hover:text-text cursor-default select-none">${row.name}</span>
        <span class="text-[12px] font-medium font-mono ${textColorClass(row.r)}">
          ${row.r.toFixed(1)}×
          <span class="text-text-tertiary text-[11px] ml-2">($${row.cost.toFixed(2)}/1M tags)</span>
        </span>
      </div>`).join('');
  }

  document.getElementById('calc-rate').addEventListener('input', () => renderCalc());
  renderHero();
</script>
