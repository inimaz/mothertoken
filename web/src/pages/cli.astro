---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import AlphaBanner from '../components/AlphaBanner.astro';
import Footer from '../components/Footer.astro';
import CliTerminal from '../components/CliTerminal.astro';
---

<Base title="mothertoken — cli">
  <div class="page">
    <Nav activeTab="cli" />
    <AlphaBanner />

    <div class="section-head">
      <span class="section-label">installation</span>
      <span class="section-rule"></span>
    </div>
    <CliTerminal commands={['pip install mothertoken']} />

    <div class="section-head">
      <span class="section-label">rank tokenizers for a language</span>
      <span class="section-rule"></span>
    </div>
    <CliTerminal
      commands={['mothertoken rank ar']}
      table={{
        headers: ['tokenizer id', 'chars/token', 'cost vs english'],
        rows: [
          ['gpt-4o', '3.132', { text: '1.56x  ← most efficient', tone: 'good' }],
          ['qwen2.5', '2.585', { text: '1.84x', tone: 'warn' }],
          ['gpt-4', '1.414', { text: '3.43x', tone: 'warn' }],
          ['mistral', '1.104', { text: '3.85x', tone: 'warn' }],
        ],
      }}
      notes={['aliases work too: arabic, spanish, thai, eng_Latn']}
    />

    <div class="section-head">
      <span class="section-label">list curated aliases</span>
      <span class="section-rule"></span>
    </div>
    <CliTerminal
      commands={['mothertoken list']}
      table={{
        headers: ['id', 'name', 'used by', 'counter source'],
        rows: [
          ['gpt-4o', 'OpenAI o200k_base', 'GPT-4o, GPT-4.1', 'tiktoken / o200k_base'],
          ['qwen2.5', 'Qwen 2.5 tokenizer', 'Qwen 2.5', 'Hugging Face / Qwen/Qwen2.5-7B'],
          ['mistral', 'Mistral 7B tokenizer', 'Mistral 7B', 'Hugging Face / mistralai/Mistral-7B-v0.1'],
          ['gemma2', 'Gemma 2 tokenizer', 'Gemma 2', 'Hugging Face / google/gemma-2-9b'],
        ],
      }}
      notes={[
        'these are starter aliases, not a complete tokenizer catalog',
        'local counters run on your machine',
      ]}
    />

    <div class="section-head">
      <span class="section-label">compare selected refs</span>
      <span class="section-rule"></span>
    </div>
    <CliTerminal
      commands={[
        'mothertoken compare "Travesura realizada"  --model gpt-4o   --model Qwen/Qwen3-0.6B  --model mistralai/Mistral-7B-v0.1',
        'mothertoken compare --file prompt.txt  --model mistralai/Mistral-7B-v0.1   --model deepseek-ai/DeepSeek-V4-Pro',
      ]}
      table={{
        headers: ['tokenizer', 'ref', 'tokens', 'chars/token'],
        rows: [
          ['OpenAI o200k_base', 'o200k_base', '4', '4.750'],
          ['Qwen/Qwen3-0.6B', 'Qwen/Qwen3-0.6B', '5', '3.800'],
          ['Mistral 7B', 'mistralai/Mistral-7B-v0.1', '6', '3.167'],
        ],
      }}
      notes={[
        'use aliases from mothertoken list or direct Hugging Face refs',
        'unknown one-word ids fail fast so typos do not become network lookups',
      ]}
    />

    <div class="section-head">
      <span class="section-label">tokenize exact text</span>
      <span class="section-rule"></span>
    </div>
    <CliTerminal
      commands={['mothertoken tokenize "مرحبا بالعالم" --language ar --model gpt-4o']}
      table={{
        headers: ['Model', 'Tokens', 'Chars/Token', 'English Est.', 'Vs English'],
        rows: [['GPT-4o', '5', '2.600', '3', '1.56x']],
      }}
      footerCommands={[
        'mothertoken tokenize "Hello" --model Qwen/Qwen3-0.6B',
        'mothertoken tokenize --file prompt.txt',
        'mothertoken tokenize --file prompt.ar.txt --language ar --english-file prompt.en.txt',
      ]}
      notes={[
        'local aliases and direct Hugging Face refs are supported',
        '--language adds benchmark English-equivalent estimates',
        '--english-text or --english-file adds a paired translation comparison',
      ]}
    />

    <div class="section-head">
      <span class="section-label">researcher workflow</span>
      <span class="section-rule"></span>
    </div>
    <CliTerminal
      commands={[
        'mothertoken-benchmark --dry-run',
        'mothertoken-benchmark --languages arb_Arab,spa_Latn --models gpt-4o,qwen2.5',
        'mothertoken-benchmark --languages eng_Latn,arb_Arab --models Qwen/Qwen3-0.6B',
      ]}
      notes={['benchmark aliases and direct Hugging Face refs are both supported']}
      cursor
    />

    <Footer />
  </div>
</Base>

<style>
.page {
  max-width: 1120px;
  margin: 0 auto;
  padding: 2rem 1.5rem 5rem;
}

</style>
