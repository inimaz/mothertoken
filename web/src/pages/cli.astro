---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CliTerminal from '../components/CliTerminal.astro';
---

<Base title="mothertoken — cli">
  <div class="page">
    <Nav activeTab="cli" />

    <div class="section-head">
      <span class="section-label">installation</span>
      <span class="section-rule"></span>
    </div>
    <CliTerminal commands={['pip install mothertoken']} />

    <div class="section-head">
      <span class="section-label">rank models for a language</span>
      <span class="section-rule"></span>
    </div>
    <CliTerminal
      commands={['mothertoken rank ar']}
      table={{
        headers: ['model', 'chars/token', 'cost vs english'],
        rows: [
          ['gpt-4o', '3.132', { text: '1.56x  ← most efficient', tone: 'good' }],
          ['qwen2.5', '2.585', { text: '1.84x', tone: 'warn' }],
          ['gpt-4', '1.414', { text: '3.43x', tone: 'warn' }],
          ['mistral', '1.104', { text: '3.85x', tone: 'warn' }],
        ],
      }}
      notes={['aliases work too: arabic, spanish, thai, eng_Latn']}
    />

    <div class="section-head">
      <span class="section-label">list models</span>
      <span class="section-rule"></span>
    </div>
    <CliTerminal
      commands={['mothertoken models']}
      table={{
        headers: ['id', 'name', 'access', 'tokenizer'],
        rows: [
          ['gpt-4o', 'GPT-4o', { text: 'local', tone: 'good' }, 'tiktoken / o200k_base'],
          ['qwen2.5', 'Qwen 2.5', { text: 'local', tone: 'good' }, 'Hugging Face / Qwen/Qwen2.5-7B'],
          ['claude-sonnet', 'Claude Sonnet', { text: 'API', tone: 'warn' }, 'Anthropic / claude-sonnet-4-6'],
          ['gemini-pro', 'Gemini Pro', { text: 'API', tone: 'warn' }, 'Google / gemini-1.5-pro'],
        ],
      }}
      footerCommands={['mothertoken models --local-only']}
    />

    <div class="section-head">
      <span class="section-label">tokenize exact text</span>
      <span class="section-rule"></span>
    </div>
    <CliTerminal
      commands={['mothertoken tokenize "مرحبا بالعالم" --language ar --model gpt-4o']}
      table={{
        headers: ['Model', 'Tokens', 'Chars/Token', 'English Est.', 'Vs English'],
        rows: [['GPT-4o', '5', '2.600', '3', '1.56x']],
      }}
      footerCommands={[
        'mothertoken tokenize --file prompt.txt',
        'mothertoken tokenize "Hello" --include-api',
        'mothertoken tokenize --file prompt.ar.txt --language ar --english-file prompt.en.txt',
      ]}
      notes={[
        'local tokenizers run by default',
        '--include-api adds provider token counters when API keys are configured',
        '--language adds benchmark English-equivalent estimates',
        '--english-text or --english-file adds a paired translation comparison',
      ]}
    />

    <div class="section-head">
      <span class="section-label">researcher workflow</span>
      <span class="section-rule"></span>
    </div>
    <CliTerminal
      commands={[
        'mothertoken-benchmark --dry-run',
        'mothertoken-benchmark --languages arb_Arab,spa_Latn --models gpt-4o,qwen2.5',
      ]}
      notes={['benchmark regeneration is documented separately from the everyday CLI']}
      cursor
    />

    <Footer />
  </div>
</Base>

<style>
.page {
  max-width: 820px;
  margin: 0 auto;
  padding: 2rem 1.5rem 5rem;
}

</style>
