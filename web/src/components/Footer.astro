---
import benchmark from "../data/benchmark";

const GITHUB_URL = "https://github.com/inimaz/mothertoken";
---

<footer
  class="flex items-center justify-between pt-8 pb-12 mt-16 border-t border-border animate-fade-in-up stagger-4"
>
  <div class="flex gap-4">
    <span class="font-mono text-[14px] text-text-tertiary"
      >corpus <span class="text-text">flores-200</span>
    </span>
    <span class="text-[14px] text-border-strong">/</span>
    <span class="font-mono text-[14px] text-text-tertiary"
      >baseline <span class="text-text">english</span>
    </span>
  </div>
  <div class="flex gap-4">
    <a
      href={GITHUB_URL}
      class="font-mono text-[14px] text-text-tertiary hover:text-text transition-colors duration-300 no-underline"
      >github↗</a
    >
    <span class="text-[14px] text-border-strong">/</span>
    <span class="font-mono text-[14px] text-text-tertiary">mit license</span>
    <span class="text-[14px] text-border-strong">/</span>
    <span class="font-mono text-[14px] text-text-tertiary"
      >v{benchmark.version}
    </span>
  </div>
</footer>
